{
  "name": "digital-journal",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "pages:dev": "npm run build && wrangler pages dev dist",
    "d1:migrate:local": "wrangler d1 execute journal-db --local --file=schema.sql",
    "d1:migrate:remote": "wrangler d1 execute journal-db --remote --file=schema.sql"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^6.0.7",
    "wrangler": "^4.110.0",
    "@cloudflare/workers-types": "^5.20260708.1"
  }
}
